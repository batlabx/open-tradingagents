# Copy to .env and adjust. Every value has a sensible local default; no keys.

# --- Models (Ollama) -------------------------------------------------------
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
DEEP_THINK_MODEL=qwen2.5:14b-instruct
QUICK_THINK_MODEL=llama3.1:8b-instruct
LLM_TEMPERATURE=0.3

# --- Debate depth ----------------------------------------------------------
MAX_DEBATE_ROUNDS=2
MAX_RISK_ROUNDS=1

# --- Data / memory ---------------------------------------------------------
LOOKBACK_DAYS=180
MEMORY_DB=trading_memory.sqlite
